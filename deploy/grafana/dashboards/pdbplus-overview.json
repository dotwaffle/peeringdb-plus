          "type": "timeseries",
          "title": "Sync Duration by Type (p95)",
          "description": "95th percentile sync duration per PeeringDB object type",
          "gridPos": { "h": 6, "w": 12, "x": 0, "y": 19 },
          "datasource": { "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "uid": "${datasource}" },
              "expr": "histogram_quantile(0.95, sum by(type, le)(rate(pdbplus_sync_type_duration_seconds_bucket{type=~\"$type\"}[$__rate_interval])))",
              "legendFormat": "{{type}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "color": { "mode": "palette-classic" },
              "custom": {
                "lineWidth": 1,
                "fillOpacity": 10,
