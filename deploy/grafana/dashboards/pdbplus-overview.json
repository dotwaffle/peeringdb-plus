              "datasource": { "uid": "${datasource}" },
              "expr": "sum by(type)(increase(pdbplus_sync_type_deleted_total{type=~\"$type\"}[$__rate_interval]))",
              "legendFormat": "{{type}}",
              "refId": "A"
