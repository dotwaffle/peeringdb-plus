  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Sync Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "text",
      "title": "Sync Health Guide",
      "description": "Documentation for sync health metrics",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 1 },
      "options": {
        "mode": "markdown",
        "content": "## Sync Health\n\nMonitors the PeeringDB data synchronization pipeline.\n\n- **Data Freshness** shows seconds since last successful sync. Green (<1h) is healthy, yellow (1-2h) means sync may be delayed, red (>2h) indicates a problem.\n- **Success Rate** should be near 100%. Drops indicate PeeringDB API issues or database write failures.\n- **Sync Duration (p95)** shows the 95th percentile sync cycle time. Normal is 30-120s depending on data volume.\n- **Fallback Events** count incremental-to-full sync fallbacks. Should be 0 under normal operation. Non-zero means the incremental sync failed and a full re-fetch was triggered.\n\n**Troubleshooting:** If freshness is red, check sync operations timeline for errors. If duration is high, check per-type sync detail row for slow types."
      },
      "datasource": { "uid": "${datasource}" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Data Freshness",
      "description": "Seconds since last successful sync",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "expr": "pdbplus_sync_freshness_seconds",
          "legendFormat": "Freshness",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "red", "value": 7200 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Sync Success Rate",
      "description": "Ratio of successful syncs to total syncs",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "expr": "sum(rate(pdbplus_sync_operations_total{status=\"success\"}[$__rate_interval])) / sum(rate(pdbplus_sync_operations_total[$__rate_interval]))",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 1,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Sync Duration (p95)",
      "description": "95th percentile sync cycle duration over time",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, rate(pdbplus_sync_duration_seconds_bucket[$__rate_interval]))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "axisPlacement": "auto",
            "drawStyle": "line",
            "gradientMode": "none",
            "barAlignment": 0,
            "lineInterpolation": "linear",
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Fallback Events",
      "description": "Count of incremental-to-full sync fallback events",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "expr": "sum(increase(pdbplus_sync_type_fallback_total[$__rate_interval]))",
          "legendFormat": "Fallbacks",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
