                ]
              },
              "color": { "mode": "thresholds" },
              "min": 0,
              "max": 1,
              "mappings": []
            },
            "overrides": []
          },
          "options": {
            "reduceOptions": {
              "values": false,
              "calcs": ["lastNotNull"],
              "fields": ""
            },
            "orientation": "auto",
            "textMode": "auto",
            "colorMode": "value",
            "graphMode": "none",
            "justifyMode": "auto"
          }
        },
        {
          "id": 12,
          "type": "stat",
          "title": "Active Requests",
          "description": "Currently in-flight HTTP requests",
          "gridPos": { "h": 6, "w": 6, "x": 18, "y": 18 },
          "datasource": { "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "uid": "${datasource}" },
              "expr": "http_server_active_requests",
              "legendFormat": "Active",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "thresholds": {
                "mode": "absolute",
